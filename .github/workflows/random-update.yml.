name: Random 12-Digit Pincode Updater

on:
  schedule:
    # Runs exactly every 12 hours
    - cron: '0 */12 * * *'
  workflow_dispatch: # Allows manual testing

jobs:
  update-file:
    runs-on: ubuntu-latest
    permissions:
      contents: write
    steps:
      - uses: actions/checkout@v4

      - name: Generate Plain Text 12-Digit Pincode
        run: |
          # Generates a random 12-digit number
          PINCODE=$(shuf -i 100000000000-999999999999 -n 1)
          
          # Overwrites the file named 'Key' with just the raw code text
          echo -n "$PINCODE" > Key

      - name: Commit and Push Changes
        run: |
          git config --global user.name "github-actions[bot]"
          git config --global user.email "github-actions[bot]@://github.com"
          git add Key
          git commit -m "Updated Key with new pincode"
          git push
